        print("Đã hoàn thành nhiệm vụ -> Chờ đổi acc...")
        SendChangeAccountSignal()
        return
    end

    UpdateUI()
    task.wait(1)
    AutoChooseTeam()
    task.wait(0.5)
    
    task.wait(1)
    EnablePVP()
    
    local hum = char:WaitForChild("Humanoid")
    hum.Died:Connect(function()
        DeathCount = DeathCount + 1
        print(">>> Chết lần " .. DeathCount .. " tại vị trí " .. CurrentLocIndex)
        
        if DeathCount >= MAX_DEATHS_PER_LOC then
            print(">>> Đã đủ " .. MAX_DEATHS_PER_LOC .. " lần chết tại vị trí " .. CurrentLocIndex)
            CurrentLocIndex = CurrentLocIndex + 1
            DeathCount = 0 -- Reset cho vị trí mới
            
            if CurrentLocIndex > #LOCATIONS then
                print(">>> ĐÃ XONG CẢ " .. #LOCATIONS .. " TỌA ĐỘ -> KÍCH HOẠT ĐỔI ACC!")
                isRunning = false
                SendChangeAccountSignal()
            else
                print(">>> CHUYỂN SANG VỊ TRÍ SỐ: " .. CurrentLocIndex)
            end
        end
        UpdateUI()
    end)
end

