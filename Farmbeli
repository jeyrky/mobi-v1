SU_LOCK = threading.Lock()
ROOT_SHELL = None

class PersistentSu:
    def __init__(self):
        self.process = subprocess.Popen(
            ["su"],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT, # Merge stderr
            text=True,
            bufsize=1
        )

    def run(self, cmd):
        token = f"__EOF_{random.randint(10000,99999)}__"
        full_cmd = f"{cmd}; echo $?; echo {token}\n"
        
        try:
            self.process.stdin.write(full_cmd)
            self.process.stdin.flush()
        except (BrokenPipeError, OSError):
            self.__init__()
            self.process.stdin.write(full_cmd)
            self.process.stdin.flush()
            
        output_lines = []
        return_code = 1
        
        while True:
            line = self.process.stdout.readline()
            if not line:
                break
            if token in line:
                break
            output_lines.append(line)
            
        if len(output_lines) >= 1:
            try:
                rc_line = output_lines[-1].strip()
                # Check if last line is an integer (return code)
                if rc_line.isdigit():
                    return_code = int(rc_line)
                    output_lines.pop() # Remove rc line
            except:
                pass
                
        return "".join(output_lines), return_code

def run_su(cmd):
    global ROOT_SHELL
    
    # Hỗ trợ ADB Mode (Windows)
    if ADB_MODE and ADB_DEVICE:
        safe_cmd = cmd.replace("'", "'\\''")
        # Chạy qua ADB Shell
        # Lưu ý: Một số lệnh như 'am', 'pm' chạy trực tiếp qua adb shell ok.
        # Nhưng 'cp', 'chown' vào /data cần quyền root.
        # Nên ta bọc trong su -c.
        full_cmd = f"adb -s {ADB_DEVICE} shell \"su -c '{safe_cmd}'\""
        return run_cmd(full_cmd)

    with SU_LOCK:
        if ROOT_SHELL is None or ROOT_SHELL.process.poll() is not None:
            try:
                ROOT_SHELL = PersistentSu()
            except Exception:
                # Fallback to old method if persistent fails
                safe_cmd = cmd.replace("'", "'\\''")
                return run_cmd(f"su -c '{safe_cmd}'")

        try:
            out, rc = ROOT_SHELL.run(cmd)
            return type('obj', (object,), {'stdout': out, 'returncode': rc})
        except Exception:
             # Fallback
             safe_cmd = cmd.replace("'", "'\\''")
             return run_cmd(f"su -c '{safe_cmd}'")

