local function isKicked()
    local function getGuiError()
        local msg = ""
        local ok = pcall(function()
            msg = GuiService.ErrorMessage
        end)
        if ok and msg and #tostring(msg) > 0 then
            local s = tostring(msg)
            local code = string.match(s, "(%d%d%d)")
            return s, code
        end
        return "", nil
    end

    local function collectText(root)
        if not root then return "", nil end
        local out = {}
        local code = nil
        for _, d in ipairs(root:GetDescendants()) do
            if d:IsA("TextLabel") or d:IsA("TextButton") or d:IsA("TextBox") then
                local t = d.Text
                if t and #t > 0 then
                    table.insert(out, t)
                    if not code then
                        local c = string.match(t, "[Ee]rror%s*[Cc]ode%s*:?%s*(%d%d%d)")
                        if c then
                            code = c
                        end
                    end
                end
            end
        end
        return table.concat(out, " | "), code
    end

    local ok, kicked, code, snippet = pcall(function()
        if not game.Players.LocalPlayer or not game.Players.LocalPlayer.Parent then
            return true, "offline", "player_nil"
        end

        local emsg, ecode = getGuiError()
        if emsg and #emsg > 0 then
            local t0 = string.lower(emsg)
            local kws0 = {"disconnected","disconnect","kicked","kick","security kick","banned","not authorized","maintenance","internet","connection","same account","please rejoin","error code","mất kết nối","mã lỗi","bảo trì","kết nối lại","reconnect","restricted","277","267","268","773"}
            for _, k in ipairs(kws0) do
                if string.find(t0, k, 1, true) then
                    return true, ecode, string.sub(emsg, 1, 300)
                end
            end
        end

        local coreGui = game:GetService("CoreGui")
        local promptGui = coreGui:FindFirstChild("RobloxPromptGui")
        local text1, code1 = collectText(promptGui)
        local pg = Players.LocalPlayer and Players.LocalPlayer:FindFirstChild("PlayerGui")
        local text2, code2 = collectText(pg)

        local text = (text1 or "") .. " " .. (text2 or "")
        local codeFound = code1 or code2
        local t = string.lower(text or "")
        local kws = {"disconnected","disconnect","kicked","kick","security kick","banned","not authorized","maintenance","internet","connection","same account","please rejoin","error code","mất kết nối","mã lỗi","bảo trì","kết nối lại","reconnect","restricted","bị kick","bị kích","bị đuổi","bị đá","vui lòng tham gia lại","tham gia lại","277","267","268","773"}
        for _, k in ipairs(kws) do
            if string.find(t, k, 1, true) then
                return true, codeFound, string.sub(text or "", 1, 300)
            end
        end
        return false
    end)
    if ok then return kicked == true, code, snippet end
    return false
end

