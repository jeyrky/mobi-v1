def start_stop_listener():
    """Khởi động luồng lắng nghe phím dừng"""
    try:
        STOP_EVT.clear()
        def _listen():
            try:
                s = input("\n[STOP] Nhập 9 rồi Enter để dừng tác vụ...\n").strip()
                if s == "9":
                    STOP_EVT.set()
            except Exception:
                pass
        t = threading.Thread(target=_listen, daemon=True)
        t.start()
    except Exception:
        pass

def wait_with_enter_check(seconds, msg_prefix):
    """Đợi seconds giây, nếu ấn Enter thì return True (Dừng)"""
    try:
        if os.name != 'nt':
            while select.select([sys.stdin], [], [], 0.0)[0]:
                sys.stdin.read(1)
    except:
        pass

    for s in range(seconds, 0, -1):
        log_status(f"{msg_prefix} Đợi {s}s... (Ấn Enter để dừng)")
        try:
            if os.name != 'nt':
                rlist, _, _ = select.select([sys.stdin], [], [], 1.0)
                if rlist:
                    sys.stdin.readline()
                    return True
            else:
                time.sleep(1)
        except:
            time.sleep(1)
    return False

def run_cmd(cmd):
    return subprocess.run(cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)

ADB_MODE = False
ADB_DEVICE = None

def get_adb_devices():
    try:
        res = subprocess.run("adb devices", shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        devices = []
        for line in res.stdout.splitlines():
            if line.strip() and "List of devices" not in line and "offline" not in line:
                parts = line.split()
                if len(parts) >= 1:
                    devices.append(parts[0])
        return devices
    except:
        return []

def init_adb():
    global ADB_MODE, ADB_DEVICE
    # Ưu tiên su nếu có (Termux)
    if shutil.which("su"):
        ADB_MODE = False
        return
    
    # Nếu không có su, thử dùng ADB (Windows)
    devs = get_adb_devices()
    if devs:
        ADB_MODE = True
        ADB_DEVICE = devs[0]
        print(f"[INIT] Chạy trên Windows (ADB Mode) -> Kết nối: {ADB_DEVICE}")
    else:
        print("[INIT] ADB Mode: Không tìm thấy thiết bị nào!")

def copy_file_to_device(local_path, remote_path):
    if ADB_MODE and ADB_DEVICE:
        # Push từ Windows vào Android
        cmd = f"adb -s {ADB_DEVICE} push \"{local_path}\" \"{remote_path}\""
        res = run_cmd(cmd)
        return res.returncode == 0
    else:
        # Copy nội bộ trên Android
        res = run_su(f"cp \"{local_path}\" \"{remote_path}\"")
        return res.returncode == 0

