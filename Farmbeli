local function readPkgName()
    local pkg = nil
    pcall(function()
        if isfile and isfile("appStorage.json") then
            local content = readfile("appStorage.json")
            if content and #content > 0 then
                local js = HttpService:JSONDecode(content)
                if js and js.PkgName then
                    pkg = js.PkgName
                end
            end
        end
    end)
    return pkg
end

local function getUsername()
    local uname = "Unknown"
    pcall(function()
        if Players.LocalPlayer then
            uname = Players.LocalPlayer.Name
        end
    end)
    return uname
end

local function writeAppStorage(fields)
    pcall(function()
        if not writefile then return end
        local js = {}
        if isfile and isfile("appStorage.json") then
            local content = readfile("appStorage.json")
            if content and #content > 0 then
                local ok, decoded = pcall(HttpService.JSONDecode, HttpService, content)
                if ok and type(decoded) == "table" then js = decoded end
            end
        end
        for k, v in pairs(fields) do js[k] = v end
        writefile("appStorage.json", HttpService:JSONEncode(js))
        pcall(function() writefile("../appStorage.json", HttpService:JSONEncode(js)) end)
    end)
end

local function urlEncode(str)
    if str == nil then return "" end
    str = tostring(str)
    str = string.gsub(str, "\n", "\r\n")
    str = string.gsub(str, "([^%w%-_%.~])", function(c)
        return string.format("%%%02X", string.byte(c))
    end)
    return str
end

function SendSignal(signalName, extraData)
    local pkgName = readPkgName()
    local uname = getUsername()
    local nonce = tostring(math.random(100000, 999999))
    local data = {
        username = uname,
        signal = signalName,
        nonce = nonce
    }
    if pkgName and pkgName ~= "" and pkgName ~= "unknown" then data.package = pkgName end
    if extraData then for k, v in pairs(extraData) do data[k] = v end end
    
    local body = HttpService:JSONEncode(data)
    local req = (syn and syn.request) or (http and http.request) or http_request or request

    for _, base in ipairs(BASES) do
        local url = base .. "/signal"
        pcall(function()
            if req then
                req({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = body})
            else
                HttpService:RequestAsync({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = body})
            end
        end)
    end
    writeAppStorage({username = uname, Signal = signalName, Nonce = nonce, Heartbeat = os.time(), PkgName = pkgName})
end

function SendReset(reason, code)
    local pkgName = readPkgName()
    local uname = getUsername()
    local nonce = tostring(math.random(100000, 999999))
    local data = {
        username = uname,
        signal = "Kicked",
        reason = reason or "Unknown",
        code = code or "0",
        nonce = nonce
    }
    if pkgName and pkgName ~= "" and pkgName ~= "unknown" then data.package = pkgName end
    
    for _, base in ipairs(BASES) do
        pcall(function()
            local url = base .. "/reset_game"
            local req = (syn and syn.request) or (http and http.request) or http_request or request
            if req then
                req({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data)})
            else
                HttpService:RequestAsync({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data)})
            end
        end)
    end
    writeAppStorage({username = uname, Signal = "Kicked", Reason = reason, Code = code, Nonce = nonce, Heartbeat = os.time(), PkgName = pkgName})
    print("[RESET] Tín hiệu Reset đã được gửi: " .. tostring(reason))
end

function SendHeartbeat(beliValue)
    local pkgName = readPkgName()
    local uname = getUsername()
    local data = {
        username = uname,
        beli = beliValue or 0,
        server_type = "FARM",
        Heartbeat = os.time()
    }
    if pkgName and pkgName ~= "" and pkgName ~= "unknown" then data.package = pkgName end
    
    for _, base in ipairs(BASES) do
        pcall(function()
            local url = base .. "/heartbeat?username=" .. urlEncode(uname) .. "&beli=" .. urlEncode(data.beli) .. "&server_type=FARM"
            if pkgName then url = url .. "&package=" .. urlEncode(pkgName) end
            local req = (syn and syn.request) or (http and http.request) or http_request or request
            if req then
                req({Url = url, Method = "GET"})
            else
                HttpService:RequestAsync({Url = url, Method = "GET"})
            end
        end)
    end
    writeAppStorage({username = uname, Heartbeat = os.time(), beli = data.beli, PkgName = pkgName})
end

