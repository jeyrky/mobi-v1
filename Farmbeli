def appstorage_poll_loop():
    # Run check once at start of thread
    check_termux_permissions()
    
    # [FIX] Lưu timestamp heartbeat cuối cùng đọc được từ file để tránh update giả
    LAST_FILE_HEARTBEAT = {} 
    
    # [FIX] Chỉ chấp nhận heartbeat trong khoảng thời gian hợp lý (tránh file cũ lưu từ hôm qua)
    MAX_HEARTBEAT_AGE = 120

    while True:
        try:
            pkgs = find_roblox_packages()
            data_map = read_appstorages(pkgs)
            for pkg, raw in data_map.items():
                if raw:
                    try:
                        js = json.loads(raw)
                        sig = js.get("Signal")
                        nonce = str(js.get("Nonce") or "")
                        last = LAST_NONCE.get(pkg, "")
                        if sig == "ChangeAccount" and nonce and nonce != last:
                            LAST_NONCE[pkg] = nonce
                            vip_idx = js.get("SignalVipIndex")
                            if vip_idx is None:
                                handle_signal(pkg)
                            else:
                                try:
                                    vi = int(vip_idx)
                                except Exception:
                                    vi = None
                                handle_signal(pkg, vi)
                        
                        elif sig == "NotEnoughBeli" and nonce and nonce != last:
                            LAST_NONCE[pkg] = nonce
                            print(f"\n[SIGNAL FILE] {pkg}: Không đủ Beli -> Switch VIP 2 (Farm)...")
                            # 1 = VIP 2
                            t = threading.Thread(target=handle_signal, args=(pkg, 1))
                            t.start()

                        elif sig == "EnoughBeliFarmDone" and nonce and nonce != last:
                            LAST_NONCE[pkg] = nonce
                            print(f"\n[SIGNAL FILE] {pkg}: Đã đủ Beli -> Switch VIP 1 (Random)...")
                            # 0 = VIP 1
                            t = threading.Thread(target=handle_signal, args=(pkg, 0))
                            t.start()

                        hb = js.get("Heartbeat") or js.get("HB") or js.get("Online") or js.get("ts")
                        if hb is not None:
                            # [FIX] Chỉ update nếu heartbeat trong file thực sự mới
                            try:
                                hb_val = float(hb)
                                
                                # [FIX] Kiểm tra độ trễ thời gian
                                if abs(time.time() - hb_val) > MAX_HEARTBEAT_AGE:
                                    continue

                                last_hb = LAST_FILE_HEARTBEAT.get(pkg, 0)
                                if hb_val > last_hb:
                                    LAST_FILE_HEARTBEAT[pkg] = hb_val
                                    HEARTBEAT_DATA[pkg] = time.time()
                                    stype = js.get("ServerType")
                                    if stype:
                                        if pkg not in HEARTBEAT_INFO: HEARTBEAT_INFO[pkg] = {}
                                        HEARTBEAT_INFO[pkg]['server_type'] = stype
                            except:
                                pass
                    except Exception:
                        pass
            # Fallback: đọc shared APPSTORAGE_FILE (khi Lua không gọi HTTP)
            try:
                if os.path.exists(APPSTORAGE_FILE):
                    with open(APPSTORAGE_FILE, "r", encoding="utf-8") as f:
                        shared_raw = f.read()
                    
                    # [DEBUG] In ra raw content để debug xem file có thay đổi không
                    # print(f"[DEBUG POLLER] Raw appStorage.json: {shared_raw[:100]}...")

                    if shared_raw:
                        js = json.loads(shared_raw)
                        
                        # [DEBUG] Check signal specifically in fallback
                        sig = js.get("Signal")
                        if sig:
                             print(f"[DEBUG POLLER] Found Signal in File: {sig}")

                        hb = js.get("Heartbeat") or js.get("HB") or js.get("Online") or js.get("ts")
                        if hb is not None:
                            try:
                                hb_val = float(hb)
                                # [FIX] Check time drift - avoid stale file content
                                if abs(time.time() - hb_val) > MAX_HEARTBEAT_AGE:
                                    raise ValueError("Heartbeat too old")

                                target_pkg = js.get("PkgName")
                                if target_pkg:
                                    # [FIX] Chỉ update nếu heartbeat trong file thực sự mới
                                    last_hb = LAST_FILE_HEARTBEAT.get(target_pkg, 0)
                                    if hb_val > last_hb:
                                        LAST_FILE_HEARTBEAT[target_pkg] = hb_val
                                        HEARTBEAT_DATA[target_pkg] = time.time()
                                        stype = js.get("ServerType")
                                        if stype:
                                            if target_pkg not in HEARTBEAT_INFO: HEARTBEAT_INFO[target_pkg] = {}
                                            HEARTBEAT_INFO[target_pkg]['server_type'] = stype
                                    
                                    # Xử lý Signal từ File Shared nếu có target_pkg
                                nonce = str(js.get("Nonce") or "")
                                last = LAST_NONCE.get(target_pkg, "")
                                
                                if sig == "NotEnoughBeli" and nonce and nonce != last:
                                    LAST_NONCE[target_pkg] = nonce
                                    print(f"\n[SIGNAL FILE SHARED] {target_pkg}: Không đủ Beli -> Switch VIP 2 (Farm)...")
                                    t = threading.Thread(target=handle_signal, args=(target_pkg, 1))
                                    t.start()
                                elif sig == "EnoughBeliFarmDone" and nonce and nonce != last:
                                    LAST_NONCE[target_pkg] = nonce
                                    print(f"\n[SIGNAL FILE SHARED] {target_pkg}: Đã đủ Beli -> Switch VIP 1 (Random)...")
                                    t = threading.Thread(target=handle_signal, args=(target_pkg, 0))
                                    t.start()
                                elif sig == "ChangeAccount" and nonce and nonce != last:
                                    LAST_NONCE[target_pkg] = nonce
                                    print(f"\n[SIGNAL FILE SHARED] {target_pkg}: Change Account...")
                                    t = threading.Thread(target=handle_signal, args=(target_pkg,))
                                    t.start()

                                uname = js.get("username") or js.get("user")
                                if uname:
                                    PKG_USERNAMES[target_pkg] = uname
                                elif len(pkgs) == 1:
                                    # Single package case
                                    p = pkgs[0]
                                    
                                    # [FIX] Chỉ update nếu heartbeat trong file thực sự mới
                                    last_hb = LAST_FILE_HEARTBEAT.get(p, 0)
                                    if hb_val > last_hb:
                                        LAST_FILE_HEARTBEAT[p] = hb_val
                                        HEARTBEAT_DATA[p] = time.time()
                                    
                                    # Logic xử lý signal cho single package
                                    nonce = str(js.get("Nonce") or "")
                                    last = LAST_NONCE.get(p, "")
                                    if sig == "NotEnoughBeli" and nonce and nonce != last:
                                        LAST_NONCE[p] = nonce
                                        print(f"\n[SIGNAL FILE SHARED] {p}: Không đủ Beli -> Switch VIP 2 (Farm)...")
                                        t = threading.Thread(target=handle_signal, args=(p, 1))
                                        t.start()
                                    elif sig == "EnoughBeliFarmDone" and nonce and nonce != last:
                                        LAST_NONCE[p] = nonce
                                        print(f"\n[SIGNAL FILE SHARED] {p}: Đã đủ Beli -> Switch VIP 1 (Random)...")
                                        t = threading.Thread(target=handle_signal, args=(p, 0))
                                        t.start()

                                    uname = js.get("username") or js.get("user")
                                    if uname:
                                        PKG_USERNAMES[p] = uname
                            except Exception:
                                pass
            except Exception as e:
                # print(f"Lỗi đọc fallback file: {e}")
                pass
        except Exception:
            pass
        # [OPTIMIZE] Giảm thời gian poll từ 5s -> 1s để phản hồi nhanh hơn
        time.sleep(1)

def start_appstorage_poll_thread():
    t = threading.Thread(target=appstorage_poll_loop)
    t.daemon = True
    t.start()

def get_adb_devices():
    try:
        res = subprocess.run("adb devices", shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        devices = []
        for line in res.stdout.splitlines():
            if line.strip() and "List of devices" not in line and "offline" not in line:
                parts = line.split()
                if len(parts) >= 1:
                    devices.append(parts[0])
        return devices
    except:
        return []

def read_appstorages(pkgs):
    data_map = {}
    devices = get_adb_devices()
    
    # 1. ADB Mode (PC controlling Phones)
    if devices:
        # Quét tất cả thiết bị ADB
        for dev in devices:
            # 1. Check thư mục chung (Fluxus/Delta hay dùng chung)
            common_paths = [
                "/storage/emulated/0/Roblox/Workspace/appStorage.json",
                "/storage/emulated/0/Roblox/workspace/appStorage.json",
                "/sdcard/Roblox/Workspace/appStorage.json",
                "/sdcard/Roblox/workspace/appStorage.json"
            ]
            
            for p in common_paths:
                try:
                    res = subprocess.run(f"adb -s {dev} shell cat {p}", shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
                    if res.returncode == 0 and res.stdout.strip():
                        try:
                            js = json.loads(res.stdout.strip())
                            p_name = js.get("PkgName")
                            if p_name: 
                                data_map[p_name] = res.stdout.strip()
                        except:
                            pass
                except:
                    pass

            # 2. Check thư mục riêng của từng package
            for pkg in pkgs:
                if pkg in data_map: continue 

                pkg_paths = [
                    f"/storage/emulated/0/Android/data/{pkg}/files/workspace/appStorage.json",
                    f"/storage/emulated/0/Android/data/{pkg}/files/Workspace/appStorage.json",
                    f"/sdcard/Android/data/{pkg}/files/workspace/appStorage.json",
                    f"/sdcard/Android/data/{pkg}/files/Workspace/appStorage.json",
                    f"/storage/emulated/0/Android/media/{pkg}/files/workspace/appStorage.json"
                ]
                
                for p in pkg_paths:
                    try:
                        res = subprocess.run(f"adb -s {dev} shell cat {p}", shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
                        if res.returncode == 0 and res.stdout.strip():
                            data_map[pkg] = res.stdout.strip()
                            break 
                    except:
                        pass

    # 2. Local SU Mode (Termux trực tiếp trên điện thoại - Fallback nếu không thấy qua ADB)
    # Hoặc nếu đang chạy trên phone thì devices có thể empty
    if not data_map:
        # Check thư mục chung local
        local_common_paths = [
            "/storage/emulated/0/Delta/Workspace/appStorage.json",
            "/storage/emulated/0/Delta/workspace/appStorage.json", # Lowercase w
            "/storage/emulated/0/delta/Workspace/appStorage.json",
            "/storage/emulated/0/delta/workspace/appStorage.json",
            
            "/storage/emulated/0/Roblox/Workspace/appStorage.json",
            "/storage/emulated/0/Roblox/workspace/appStorage.json",
            "/sdcard/Roblox/Workspace/appStorage.json",
            "/sdcard/Roblox/workspace/appStorage.json",
            
             # Thêm path cụ thể của các executor phổ biến
            "/storage/emulated/0/Android/data/com.fluxus.fluxus/files/workspace/appStorage.json",
            "/storage/emulated/0/Android/data/com.delta.roblox/files/workspace/appStorage.json",
            "/storage/emulated/0/Android/data/com.hydrogen.roblox/files/workspace/appStorage.json"
        ]
        
        for p in local_common_paths:
            # Method 0: Direct Read (Fastest, works if Termux has storage permission)
            try:
                if os.path.exists(p):
                    try:
                        with open(p, "r", encoding="utf-8", errors="ignore") as f:
                            content = f.read().strip()
                        if content:
                            try:
                                js = json.loads(content)
                                p_name = js.get("PkgName")
                                if not p_name or p_name == "unknown":
                                    if len(pkgs) >= 1:
                                        p_name = pkgs[0]
                                if p_name: 
                                    data_map[p_name] = content
                                    continue # Done with this path
                            except:
                                pass
                    except:
                        pass
            except:
                pass

            # Method 1: Root Read (Fallback)
            try:
                res = run_su(f"cat '{p}'")
                
                if res.returncode == 0 and res.stdout.strip():
                    try:
                        js = json.loads(res.stdout.strip())
                        p_name = js.get("PkgName")
                        
                        # [FIX] Nếu PkgName là unknown hoặc thiếu, thử đoán bằng danh sách package đang chạy
                        if not p_name or p_name == "unknown":
                            if len(pkgs) >= 1:
                                p_name = pkgs[0] 

                        if p_name: 
                            data_map[p_name] = res.stdout.strip()
                    except:
                        pass
            except:
                pass
                
        # Check thư mục riêng từng package local
        for pkg in pkgs:
            if pkg in data_map: continue

            local_pkg_paths = [
                f"/storage/emulated/0/Android/data/{pkg}/files/workspace/appStorage.json",
                f"/storage/emulated/0/Android/data/{pkg}/files/Workspace/appStorage.json",
                f"/sdcard/Android/data/{pkg}/files/workspace/appStorage.json",
                f"/sdcard/Android/data/{pkg}/files/Workspace/appStorage.json",
                f"/storage/emulated/0/Android/media/{pkg}/files/workspace/appStorage.json"
            ]
            for p in local_pkg_paths:
                try:
                    res = run_su(f"cat {p}")
                    if res.returncode == 0 and res.stdout.strip():
                        data_map[pkg] = res.stdout.strip()
                        break
                except:
                    pass

    return data_map

