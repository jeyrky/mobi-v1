-- KICK DETECTION
--------------------------------------------------------------------------------
local function isKicked()
    local ok, kicked, code, snippet = pcall(function()
        if os.clock() < 10 then return false end
        if not game.Players.LocalPlayer or not game.Players.LocalPlayer.Parent then return true, "offline", "player_nil" end

        local emsg = GuiService.ErrorMessage
        if emsg and #emsg > 0 then
            local t0 = string.lower(emsg)
            local kws0 = {"disconnected", "kicked", "security kick", "banned", "maintenance", "same account", "error code", "mất kết nối", "mã lỗi", "bảo trì", "restricted", "unexpected", "client behavior", "out of memory"}
            for _, k in ipairs(kws0) do if string.find(t0, k, 1, true) then return true, "gui_err", emsg end end
        end

        local coreGui = game:GetService("CoreGui")
        local promptGui = coreGui:FindFirstChild("RobloxPromptGui")
        if promptGui then
            for _, d in ipairs(promptGui:GetDescendants()) do
                if (d:IsA("TextLabel") or d:IsA("TextButton")) and d.Text and #d.Text > 0 then
                    local t = string.lower(d.Text)
                    local kws = {"disconnected", "kicked", "security kick", "banned", "maintenance", "same account", "error code", "mất kết nối", "mã lỗi", "bị kick", "vui lòng tham gia lại", "không thể kết nối", "mất mạng", "văng game", "unexpected client behavior"}
                    for _, k in ipairs(kws) do if string.find(t, k, 1, true) then return true, "prompt_err", d.Text end end
                end
            end
        end
        return false
    end)
    if ok then return kicked == true, code, snippet end
    return false
end

