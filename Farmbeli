local function readPkgName()
    local pkg = nil
    pcall(function()
        if isfile and isfile("appStorage.json") then
            local content = readfile("appStorage.json")
            if content and #content > 0 then
                local js = HttpService:JSONDecode(content)
                if js and js.PkgName then
                    pkg = js.PkgName
                end
            end
        end
    end)
    return pkg
end

local function getUsername()
    local uname = "Unknown"
    pcall(function()
        if Players.LocalPlayer then
            uname = Players.LocalPlayer.Name
        end
    end)
    return uname
end

local function writeAppStorage(fields)
    pcall(function()
        if not writefile then
            return
        end
        local js = {}
        if isfile and isfile("appStorage.json") then
            local content = readfile("appStorage.json")
            if content and #content > 0 then
                local ok, decoded = pcall(HttpService.JSONDecode, HttpService, content)
                if ok and type(decoded) == "table" then
                    js = decoded
                end
            end
        end
        for k, v in pairs(fields) do
            js[k] = v
        end
        writefile("appStorage.json", HttpService:JSONEncode(js))
        pcall(function()
            writefile("../appStorage.json", HttpService:JSONEncode(js))
        end)
    end)
end

