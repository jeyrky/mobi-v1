        return False
    
    # Lấy index tiếp theo
    curr_idx = COOKIE_INDEXES.get(pkg, -1)
    
    # Nếu có vip_server_index (được gửi từ Lua để yêu cầu đổi server),
    # ta giữ nguyên cookie hiện tại mà chỉ đổi server (inject lại cùng cookie nhưng server khác).
    # Tuy nhiên, logic cũ là đổi ACCOUNT.
    # User request: "khi không đủ beli sẽ gửi tín hiệu lên python... chuyển severvip 2"
    # Điều này có nghĩa là đổi Server nhưng vẫn giữ Account cũ? Hay đổi cả Account?
    # Theo ngữ cảnh "auto chest... gửi tín hiệu... chuyển vip 2", thường là đổi server để farm tiếp.
    # Nhưng tên hàm là ChangeAccount.
    # Nếu Lua gửi ChangeAccount kèm SignalVipIndex, ta sẽ ưu tiên đổi Server.
    
    cfg = load_config()
    is_no_loop = bool(OPTION5_ACTIVE or OPTION6_ACTIVE or (not cfg.get("loop_infinite", False)))

    if vip_server_index is not None:
        new_index = 0 if curr_idx < 0 else curr_idx
        log_msg = f"[SMART] {pkg} -> Đổi Server VIP (Index: {vip_server_index})"
        nick_suffix = f"[Nick {new_index+1}/{len(cookies)} | VIP {vip_server_index}]"
    else:
        if is_no_loop:
            new_index = 0 if curr_idx < 0 else (curr_idx + 1)
            if new_index >= len(cookies):
                log_status(f"[{pkg}] Đã chạy hết danh sách Cookie (No Loop). Dừng lại.")
                force_stop(pkg)
                if pkg not in NO_LOOP_DONE_PKGS:
                    NO_LOOP_DONE_PKGS.add(pkg)
                if (OPTION5_ACTIVE or OPTION6_ACTIVE) and ACTIVE_RUN_PKGS and all(p in NO_LOOP_DONE_PKGS for p in ACTIVE_RUN_PKGS):
                    STOP_EVT.set()
                return False
            log_msg = f"[SIGNAL] {pkg} -> Đổi sang Account #{new_index+1}/{len(cookies)}"
            nick_suffix = f"[Auto {new_index+1}/{len(cookies)}]"
        else:
            if curr_idx != -1:
                 RANDOM_DONE_TS[curr_idx] = time.time()

            start_search = (curr_idx + 1) % len(cookies)
            found_idx = -1
            min_wait = float('inf')

            for i in range(len(cookies)):
                check_idx = (start_search + i) % len(cookies)
                last_run = RANDOM_DONE_TS.get(check_idx, 0)
                wait_time = 7200 - (time.time() - last_run)

                if wait_time <= 0:
                    found_idx = check_idx
                    break
                else:
                    if wait_time < min_wait:
                        min_wait = wait_time

            if found_idx != -1:
                new_index = found_idx
                log_msg = f"[SIGNAL] {pkg} -> Đổi sang Account #{new_index+1}/{len(cookies)} (Ready)"
            else:
                print(f" -> [WAIT] Tất cả account đều đang chờ cooldown (Min wait: {int(min_wait)}s).")
                print(f" -> Đợi {int(min_wait)}s rồi thử lại...")
                time.sleep(min_wait + 2)
                for i in range(len(cookies)):
                    check_idx = (start_search + i) % len(cookies)
                    last_run = RANDOM_DONE_TS.get(check_idx, 0)
                    if time.time() - last_run >= 7200:
                        new_index = check_idx
                        log_msg = f"[SIGNAL] {pkg} -> Đổi sang Account #{new_index+1}/{len(cookies)} (After Wait)"
                        break
                if new_index == -1:
                     new_index = start_search
                     log_msg = f"[WARN] Force run Account #{new_index+1}/{len(cookies)}"

            nick_suffix = f"[Auto {new_index+1}/{len(cookies)}]"

    COOKIE_INDEXES[pkg] = new_index
    
    if (OPTION5_ACTIVE or OPTION6_ACTIVE) and vip_server_index is None:
        global TOTAL_ACCOUNTS_PROCESSED
        TOTAL_ACCOUNTS_PROCESSED += 1
    
    cookie = cookies[new_index]
    
    print(f"\n{log_msg}")
    
    # Inject lại
    try:
        # [FIX] Khi đổi nick (vip_server_index=None), cần truyền đúng index server hiện tại 
        # để inject_cookie biết đường mở đúng link VIP (thay vì default=0)
        target_vip_idx = vip_server_index
        if target_vip_idx is None:
            target_vip_idx = CURRENT_VIP_INDEX.get(pkg, 0)
            
        inject_cookie(cookie, cfg, pkg, nickname=nick_suffix, vip_server_index=target_vip_idx)
        return True
    except Exception as e:
        print(f"Lỗi đổi nick: {e}")
        return False

