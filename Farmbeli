def to_webkit_time(dt):
    if dt.tzinfo is not None:
        dt = dt.replace(tzinfo=None)
    epoch = datetime(1601, 1, 1)
    delta = dt - epoch
    return int(delta.total_seconds() * 1000000)

def cookie_columns(conn):
    cur = conn.cursor()
    cur.execute("PRAGMA table_info(cookies)")
    return [r[1] for r in cur.fetchall()]

def ensure_table(conn):
    try:
        cols = cookie_columns(conn)
    except sqlite3.DatabaseError:
        cols = []
    
    if len(cols) == 0:
        conn.execute("""
            CREATE TABLE IF NOT EXISTS cookies (
                creation_utc INTEGER NOT NULL,
                host_key TEXT NOT NULL,
                top_frame_site_key TEXT NOT NULL,
                name TEXT NOT NULL,
                value TEXT NOT NULL,
                encrypted_value BLOB NOT NULL,
                path TEXT NOT NULL,
                expires_utc INTEGER NOT NULL,
                is_secure INTEGER NOT NULL,
                is_httponly INTEGER NOT NULL,
                last_access_utc INTEGER NOT NULL,
                has_expires INTEGER NOT NULL,
                is_persistent INTEGER NOT NULL,
                priority INTEGER NOT NULL,
                samesite INTEGER NOT NULL,
                source_scheme INTEGER NOT NULL,
                source_port INTEGER NOT NULL,
                last_update_utc INTEGER NOT NULL
            )
        """)
        conn.execute("CREATE UNIQUE INDEX IF NOT EXISTS cookies_unique_index ON cookies(host_key, top_frame_site_key, name, path, source_scheme, source_port)")
        conn.commit()

def find_cookie_template():
    candidates = [
        os.path.join(BASE_DIR, "Cookies"),
        os.path.join(BASE_DIR, "Cookies", "Cookies")
    ]
    for p in candidates:
        if os.path.isfile(p):
            return p
    return None

def prepare_cookie_db(path, value):
    template_path = find_cookie_template()
    if template_path:
        try:
            if os.path.exists(path): os.remove(path)
            shutil.copy2(template_path, path)
        except Exception:
            pass
    
    conn = sqlite3.connect(path)
    try:
        ensure_table(conn)
    except Exception:
        conn.close()
        if os.path.exists(path): os.remove(path)
        conn = sqlite3.connect(path)
        ensure_table(conn)

    cols = cookie_columns(conn)
    now = datetime.utcnow()
    expire = now + timedelta(days=365)
    
    data = {
        "creation_utc": to_webkit_time(now),
        "host_key": ".roblox.com",
        "name": ".ROBLOSECURITY",
        "value": value,
        "encrypted_value": b"",
        "path": "/",
        "expires_utc": to_webkit_time(expire),
        "is_secure": 1,
        "is_httponly": 1,
        "last_access_utc": to_webkit_time(now),
        "last_update_utc": to_webkit_time(now),
        "has_expires": 1,
        "is_persistent": 1,
        "samesite": 0,
        "priority": 1,
        "source_scheme": 2,
        "source_port": 0,
        "is_same_party": 0,
        "top_frame_site_key": "",
        "source_type": 0,
        "has_cross_site_ancestor": 0,
    }

    try:
        if "name" in cols:
            conn.execute("DELETE FROM cookies WHERE name IN (?,?)", (".ROBLOSECURITY", "ROBLOSECURITY"))
            conn.execute("DELETE FROM cookies WHERE name LIKE ?", ("%ROBLOSECURITY%",))
        if all(c in cols for c in ["host_key","name"]):
            conn.execute("DELETE FROM cookies WHERE host_key LIKE ? AND name LIKE ?", ("%roblox.com%", "%ROBLOSECURITY%"))
    except Exception as e:
        print(f"DEBUG: Lỗi xóa cookie cũ: {e}")

    insert_cols = [c for c in cols if c in data]
    placeholders = ",".join(["?" for _ in insert_cols])
    sql = f"INSERT OR REPLACE INTO cookies ({','.join(insert_cols)}) VALUES ({placeholders})"
    
    try:
        conn.execute(sql, [data[c] for c in insert_cols])
        conn.commit()
    except Exception as e:
        print(f"DEBUG: Lỗi chèn cookie mới: {e}")
    finally:
        conn.close()

def valid_cookie_lines(lines):
    import re
    res = []
    for s in lines:
        t = s.lstrip("\ufeff").strip()
        if not t: continue
        if t.startswith("\"") and t.endswith("\""):
            t = t[1:-1].strip()
        m = re.search(r"_\|WARNING:-DO-NOT-SHARE-THIS.*", t)
        if m:
            res.append(m.group(0).strip())
            continue
        m2 = re.search(r"WARNING:-DO-NOT-SHARE-THIS.*", t)
        if m2:
            res.append("_|" + m2.group(0).strip())
    return res

def read_cookies():
    global COOKIE_TOTAL
    if not os.path.exists(COOKIES_TXT_FILE):
        COOKIE_TOTAL = 0
        return []
    with open(COOKIES_TXT_FILE, "r", encoding="utf-8") as f:
        lines = [l.strip() for l in f.readlines()]
    cookies = valid_cookie_lines(lines)
    COOKIE_TOTAL = len(cookies)
    return cookies

def find_roblox_packages():
    """Tìm tất cả các package có tên chứa 'roblox'"""
    print(" -> Đang quét tìm các bản Roblox (Clone)...", end="\r")
    res = run_su("pm list packages | grep roblox")
    if res.returncode != 0:
        return []
    
    pkgs = []
    for line in res.stdout.splitlines():
        line = line.strip()
        if line.startswith("package:"):
            p = line.replace("package:", "").strip()
            pkgs.append(p)
    return sorted(pkgs)

def wait_for_cookie_file(pkg, timeout=10.0):
    start = time.time()
    candidates = [
        f"/data/data/{pkg}/app_webview/Default/Network/Cookies",
        f"/data/data/{pkg}/app_webview/Default/Cookies",
        f"/data/data/{pkg}/app_webview/Network/Cookies",
        f"/data/data/{pkg}/app_webview/Cookies",
    ]
    while time.time() - start < timeout:
        for p in candidates:
            # Check if file exists
            res = run_su(f"ls {p}")
            if res.returncode == 0 and "No such file" not in res.stdout and "not found" not in res.stdout:
                return p
        time.sleep(0.5)
    return f"/data/data/{pkg}/app_webview/Default/Cookies"

def check_cookie_status(cookie):
    """
    Check cookie sống hay chết.
    Return True nếu Live (hoặc lỗi mạng không xác định).
    Return False nếu Die (401 Unauthorized).
    """
    url = "https://users.roblox.com/v1/users/authenticated"
    try:
        req = urllib.request.Request(url)
        req.add_header("Cookie", f".ROBLOSECURITY={cookie}")
        # Timeout 5s để không treo quá lâu
        with urllib.request.urlopen(req, timeout=5) as response:
            if response.getcode() == 200:
                return True
    except urllib.error.HTTPError as e:
        if e.code == 401:
            return False
    except Exception as e:
        # Lỗi mạng hoặc timeout -> Coi như Live để thử login
        print(f" [Check Cookie] Lỗi check (giả định Live): {e}")
        return True
    return True

def handle_dead_cookie(cookie):
    """Ghi log die và xóa khỏi cookies.txt"""
    # 1. Ghi vào file die
    die_file = os.path.join(BASE_DIR, "cookies_die.txt")
    try:
        with open(die_file, "a", encoding="utf-8") as f:
            f.write(cookie + "\n")
        print(f" -> Đã lưu cookie die vào {die_file}")
    except Exception as e:
        print(f"Lỗi ghi file die: {e}")

    # 2. Xóa khỏi cookies.txt
    try:
        # Đọc lại file trực tiếp để đảm bảo mới nhất
        if os.path.exists(COOKIES_TXT_FILE):
            with open(COOKIES_TXT_FILE, "r", encoding="utf-8") as f:
                lines = [l.strip() for l in f.readlines() if l.strip()]
            
            if cookie in lines:
                lines.remove(cookie)
                with open(COOKIES_TXT_FILE, "w", encoding="utf-8") as f:
                    for l in lines:
                        f.write(l + "\n")
                print(f" -> Đã xóa cookie die khỏi danh sách. Còn lại: {len(lines)}")
    except Exception as e:
        print(f"Lỗi xóa cookie die: {e}")

