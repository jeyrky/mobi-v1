local function SendHeartbeat(extraData)
    local pkgName = readPkgName()
    local uname = getUsername()
    local stype = "FARM"
    local beli = nil
    if extraData and extraData.beli ~= nil then
        beli = extraData.beli
    end

    local req = (syn and syn.request) or (http and http.request) or http_request or request

    for _, base in ipairs(BASES) do
        local url = base .. "/heartbeat"
        if pkgName and pkgName ~= "" and pkgName ~= "unknown" then
            url = url .. "?package=" .. urlEncode(pkgName) .. "&username=" .. urlEncode(uname) .. "&server_type=" .. urlEncode(stype)
        else
            url = url .. "?username=" .. urlEncode(uname) .. "&server_type=" .. urlEncode(stype)
        end
        if beli ~= nil then
            url = url .. "&beli=" .. urlEncode(beli)
        end
        if req then
            pcall(function()
                req({Url = url, Method = "GET"})
            end)
        end
        pcall(function()
            HttpService:RequestAsync({
                Url = url,
                Method = "GET",
                Headers = {["Content-Type"] = "application/json"}
            })
        end)
    end

    local fields = {
        username = uname,
        Heartbeat = os.time()
    }
    if pkgName and pkgName ~= "" and pkgName ~= "unknown" then
        fields.PkgName = pkgName
    end
    writeAppStorage(fields)
end

function GetCurrentBeli()
