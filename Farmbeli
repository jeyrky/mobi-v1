                lastChange = os.clock()
            else
                -- Tăng lên 90s để phù hợp với tốc độ farm chest (tránh hop quá sớm)
                if os.clock() - lastChange >= 90 then
                    hopping = true
                    print("[FARM BELI] 90s không tăng Beli -> Hop server ít người...")
                    pcall(function()
                        SendSignal("HopLowUser", {beli = cur})
                    end)
                    task.wait(0.5)
                    smartHopLowUser()
                    task.wait(15) -- Đợi teleport
                    lastChange = os.clock()
                    hopping = false
                end
            end
        end
    end
end)

