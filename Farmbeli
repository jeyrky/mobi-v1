local function smartHopLowUser()
    HOP_TOKEN = HOP_TOKEN + 1
    local hopToken = HOP_TOKEN
    local startJobId = game.JobId

    local visited = loadVisited()
    local visitedSet = {}
    for _, id in ipairs(visited) do visitedSet[id] = true end

    ensureTeleportHooks()

    local minFreeSlots = 3
    local maxScanPages = 10
    local maxCandidates = 35
    local maxTeleportTries = 8
    local teleportWait = 12
    local failWindow = 4

    local function isGameFull(result, message)
        local r = tostring(result or "")
        local m = tostring(message or "")
        r = string.lower(r)
        m = string.lower(m)
        if string.find(r, "gamefull") then return true end
        if string.find(m, "full") then return true end
        if string.find(m, "maximum") and string.find(m, "players") then return true end
        return false
    end

    local function tryTeleportTo(serverId)
        local startTs = TELEPORT_FAIL_TS
        local ok = pcall(function()
            TeleportService:TeleportToPlaceInstance(game.PlaceId, serverId, LocalPlayer)
        end)
        if not ok then
            return false, "pcall_failed", nil
        end
        local t0 = os.clock()
        while os.clock() - t0 < failWindow do
            if TELEPORT_FAIL_TS ~= startTs then
                return false, TELEPORT_FAIL_RESULT, TELEPORT_FAIL_MSG
            end
            task.wait(0.2)
        end
        task.spawn(function()
            task.wait(teleportWait)
            if HOP_TOKEN == hopToken and game.JobId == startJobId then
                smartHopLowUser()
            end
        end)
        return true, nil, nil
    end

    local req = (syn and syn.request) or http_request or request
    local candidates = {}

    local function scanServers(minSlots)
        local out = {}
        local cur = ""
        for i = 1, maxScanPages do
            local url = "https://games.roblox.com/v1/games/" .. tostring(game.PlaceId) .. "/servers/Public?sortOrder=Asc&limit=100&cursor=" .. cur
            local ok, res = pcall(function() return req({Url = url, Method = "GET"}) end)
            if ok and res and res.Body then
                local data = HttpService:JSONDecode(res.Body)
                if data and data.data then
                    for _, server in ipairs(data.data) do
                        local playing = server.playing or 0
                        local maxPlayers = server.maxPlayers or 12
                        local free = (maxPlayers - playing)
                        if server.id and server.id ~= game.JobId and free >= minSlots and not visitedSet[server.id] then
                            table.insert(out, {id = server.id, playing = playing, free = free})
                            if #out >= maxCandidates then
                                break
                            end
                        end
                    end
                end
                if #out >= maxCandidates then break end
                if data and data.nextPageCursor then cur = data.nextPageCursor else break end
            end
            task.wait(0.1)
        end
        return out
    end

    if req then
        candidates = scanServers(minFreeSlots)
        if #candidates == 0 then
            candidates = scanServers(1)
        end
    end

    if #candidates > 0 then
        table.sort(candidates, function(a, b)
            return (a.playing or 0) < (b.playing or 0)
        end)

        local topN = math.min(#candidates, 12)
        local picks = {}
        for i = 1, topN do
            table.insert(picks, candidates[i])
        end
        for i = #picks, 2, -1 do
            local j = math.random(1, i)
            picks[i], picks[j] = picks[j], picks[i]
        end

        local tries = 0
        for _, s in ipairs(picks) do
            tries = tries + 1
            if tries > maxTeleportTries then break end
            local ok, r, m = tryTeleportTo(s.id)
            if ok then
                pcall(function()
                    saveVisited(s.id)
                end)
                return
            else
                if not isGameFull(r, m) then
                    pcall(function()
                        saveVisited(s.id)
                    end)
                end
                task.wait(0.4)
            end
        end
    end

    TeleportService:Teleport(game.PlaceId, LocalPlayer)
end

