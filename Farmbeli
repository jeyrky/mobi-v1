def _sh_quote(s):
    """Quote an toàn cho sh: '...' với escape dấu nháy trong chuỗi."""
    return "'" + str(s).replace("'", "'\\''") + "'"


def _deeplink_am_cmd(url, pkg):
    """
    Một dòng lệnh am start VIEW. URL bọc '...' để ký tự & ? = không bị shell cắt.
    --es giúp một số ROM không chuyển link sang trình duyệt.
    """
    u = _sh_quote((url or "").strip())
    return (
        f"am start -a android.intent.action.VIEW -d {u} -p {pkg} "
        f"--es com.android.browser.application_id {pkg}"
    )


def _ensure_roblox_applinks(pkg):
    """Android 12+: luôn mở roblox.com bằng đúng package (clone). Lệnh cũ --auto-approve không hợp lệ."""
    for domain in ("roblox.com", "www.roblox.com"):
        run_su(
            f"pm set-app-links-user-selection --user 0 --package {pkg} {domain} always 2>/dev/null || true"
        )


def _run_deeplink_once(url, pkg):
    """Chạy intent VIEW: ADB dùng argv (không shell=True) để URL có & không bị Windows CMD phá."""
    inner = _deeplink_am_cmd(url, pkg)
    if ADB_MODE and ADB_DEVICE:
        subprocess.run(
            ["adb", "-s", ADB_DEVICE, "shell", "sh", "-c", inner],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    else:
        run_su(inner)


def open_url(url, pkg, retries=3, wait_after_launch=5):
    """
    Mở link VIP / private server vào đúng Roblox (clone).
    - App Links đúng domain; đợi app khởi động; gửi deep link có thể lặp (Roblox đôi khi bỏ intent lần 1).
    """
    url = (url or "").strip()
    if not url:
        return

    _ensure_roblox_applinks(pkg)
    run_su(f"monkey -p {pkg} -c android.intent.category.LAUNCHER 1")
    time.sleep(max(3, float(wait_after_launch)))

    n = max(1, int(retries))
    for i in range(n):
        _run_deeplink_once(url, pkg)
        if i < n - 1:
            time.sleep(2.5)


def open_place_id(pkg, place_id):
    """robloxmobile://placeId=... — dùng chung pipeline open_url."""
    open_url(f"robloxmobile://placeId={int(place_id)}", pkg, retries=3, wait_after_launch=5)

