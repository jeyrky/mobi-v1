local function isKicked()
    local function getGuiError()
        local msg = ""
        local ok = pcall(function()
            msg = GuiService.ErrorMessage
        end)
        if ok and msg and #tostring(msg) > 0 then
            local s = tostring(msg)
            local code = string.match(s, "(%d%d%d)")
            return s, code
        end
        return "", nil
    end

    local function collectText(root)
        if not root then return "", nil end
        local out = {}
        local code = nil
        -- Chỉ quét tối đa 50 descendants để tránh lag và chỉ quét TextLabel/TextButton có liên quan đến thông báo lỗi
        local count = 0
        for _, d in ipairs(root:GetDescendants()) do
            count = count + 1
            if count > 100 then break end
            
            if d:IsA("TextLabel") or d:IsA("TextButton") then
                local t = d.Text
                if t and #t > 0 then
                    -- Kiểm tra xem TextLabel này có nằm trong một khung thông báo (Prompt) không
                    local isPrompt = false
                    local p = d.Parent
                    while p and p ~= root do
                        if string.find(string.lower(p.Name), "prompt") or string.find(string.lower(p.Name), "error") or string.find(string.lower(p.Name), "message") then
                            isPrompt = true
                            break
                        end
                        p = p.Parent
                    end

                    if isPrompt or root.Name == "RobloxPromptGui" then
                        table.insert(out, t)
                        if not code then
                            local c = string.match(t, "[Ee]rror%s*[Cc]ode%s*:?%s*(%d%d%d)")
                            if c then
                                code = c
                            end
                        end
                    end
                end
            end
        end
        return table.concat(out, " | "), code
    end

    local ok, kicked, code, snippet = pcall(function()
        -- Không check khi mới vào game dưới 10 giây để tránh nhận diện nhầm UI đang load
        if os.clock() < 10 then
            return false
        end

        if not game.Players.LocalPlayer or not game.Players.LocalPlayer.Parent then
            return true, "offline", "player_nil"
        end

        local emsg, ecode = getGuiError()
        if emsg and #emsg > 0 then
            local t0 = string.lower(emsg)
            -- Các từ khóa lỗi nghiêm trọng từ Roblox (GuiService)
            local kws0 = {
                "disconnected", "kicked", "security kick", "banned", "not authorized", 
                "maintenance", "same account", "error code", 
                "mất kết nối", "mã lỗi", "bảo trì", "kết nối lại", "restricted", "unexpected",
                "client behavior", "out of memory",
            }
            for _, k in ipairs(kws0) do
                if string.find(t0, k, 1, true) then
                    return true, ecode, string.sub(emsg, 1, 300)
                end
            end
        end

        local coreGui = game:GetService("CoreGui")
        local promptGui = coreGui:FindFirstChild("RobloxPromptGui")
        local text1, code1 = collectText(promptGui)
        
        -- Chỉ quét PlayerGui nếu thực sự có thông báo lỗi hiện lên
        local text2, code2 = "", nil
        local pg = Players.LocalPlayer:FindFirstChild("PlayerGui")
        if pg then
            -- Chỉ quét các UI có tên chứa 'Error', 'Prompt', 'Disconnect' trong PlayerGui
            for _, v in ipairs(pg:GetChildren()) do
                local name = string.lower(v.Name)
                if string.find(name, "error") or string.find(name, "prompt") or string.find(name, "disconnect") or string.find(name, "kick") then
                    local t, c = collectText(v)
                    if t and #t > 0 then
                        text2 = text2 .. " " .. t
                        code2 = code2 or c
                    end
                end
            end
        end

        local text = (text1 or "") .. " " .. (text2 or "")
        local codeFound = code1 or code2
        local t = string.lower(text or "")
        
        -- Các từ khóa lỗi nghiêm trọng từ UI
        local kws = {
            "disconnected", "kicked", "security kick", "banned", "not authorized", 
            "maintenance", "same account", "error code", 
            "mất kết nối", "mã lỗi", "bảo trì", "kết nối lại", "restricted", "bị kick", 
            "bị kích", "bị đuổi", "bị đá", "vui lòng tham gia lại", "không thể kết nối",
            "mất mạng", "văng game", "unexpected client behavior",
            "277", "267", "268", "773", "279", "610", "524", "529", "273"
        }
        
        for _, k in ipairs(kws) do
            if string.find(t, k, 1, true) then
                -- Tránh nhận diện nhầm các từ khóa thông thường
                if (k == "teleport" and not string.find(t, "failed")) or (k == "lỗi" and (string.find(t, "chọn") or string.find(t, "đổi"))) then
                    continue
                end
                return true, codeFound, string.sub(text or "", 1, 300)
            end
        end
        return false
    end)
    if ok then return kicked == true, code, snippet end
    return false
end

