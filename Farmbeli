def load_config():
    if not os.path.exists(CONFIG_FILE):
        save_config(DEFAULT_CONFIG)
        return DEFAULT_CONFIG.copy()
    try:
        with open(CONFIG_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
            
            # Đảm bảo các trường mặc định
            for k, v in DEFAULT_CONFIG.items():
                if k not in data and k not in ["vip_urls", "vip_index"]:
                    data[k] = v
            
            # Tự động tạo list vip_urls từ vip1/vip2 để dùng trong code
            vips = resolve_vip_links(data)
            data["vip_urls"] = vips
            
            # Luôn mặc định vip_index = 0 (VIP 1) khi load config
            # Vì user không muốn lưu trạng thái ưu tiên
            data["vip_index"] = 0
            
            return data
    except Exception:
        return DEFAULT_CONFIG.copy()

