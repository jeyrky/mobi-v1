def option6_monitor_loop(pkgs, target_beli):
    """
    Monitor dành riêng cho Option 6 (Farm Beli).
    - Mặc định: Chỉ đợi tín hiệu "EnoughBeliFarmDone" -> Đổi Acc.
    - Nếu "NotEnoughBeli" -> Giữ nguyên (tiếp tục farm).
    - Nếu "ChangeAccount" -> Đổi Acc.
    """
    last_update = 0
    TIMEOUT_1 = 300 # 5 phút không online -> Restart
    
    RETRY_COUNTS = {}
    LAST_BELI_SWITCH = {}
    
    while True:
        if STOP_EVT.is_set():
            break
        now = time.time()
        total_cookies = COOKIE_TOTAL or len(read_cookies())
        rows = []
        for pkg in pkgs:
            last = HEARTBEAT_DATA.get(pkg, 0)
            base = last or OPEN_TS.get(pkg, 0)
            
            # Reset retry count if online recently
            if last > 0 and (now - last < 60):
                RETRY_COUNTS[pkg] = 0
                
            status = ""
            seen = ""
            
            if last > 0 and (now - last < 60):
                info = HEARTBEAT_INFO.get(pkg, {}) or {}
                beli = info.get("beli")
                if beli is not None:
                    try:
                        beli_val = int(beli)
                    except Exception:
                        beli_val = None
                else:
                    beli_val = None

                if beli_val is not None and beli_val >= int(target_beli):
                    last_sw = LAST_BELI_SWITCH.get(pkg, 0)
                    if now - last_sw > 30:
                        LAST_BELI_SWITCH[pkg] = now
                        def _async_switch_account(p):
                            try:
                                log_status(f"[MONITOR] {p}: Đủ Beli ({beli_val:,} >= {int(target_beli):,}) -> Đổi Acc...")
                                handle_signal(p)
                            except Exception:
                                pass
                        HEARTBEAT_DATA[pkg] = 0
                        OPEN_TS[pkg] = time.time()
                        threading.Thread(target=_async_switch_account, args=(pkg,), daemon=True).start()
                        status = "SWITCH"
                        seen = "-"
                        idx = COOKIE_INDEXES.get(pkg, -1)
                        nick = f"{idx+1}/{total_cookies}" if idx >= 0 and total_cookies > 0 else "-"
                        rows.append((pkg, nick, status, seen))
                        continue

                status = "FARMING"
                seen = f"{int(now - last)}s"
            else:
                if base == 0:
                    status = "INIT"
                    seen = "-"
                else:
                    diff = now - base
                    if diff > TIMEOUT_1:
                        # Quá lâu không online -> Restart lại
                        if RETRY_COUNTS.get(pkg, 0) == 0:
                            handle_reset(pkg)
                            OPEN_TS[pkg] = time.time()
                            HEARTBEAT_DATA[pkg] = 0
                            RETRY_COUNTS[pkg] = 1
                            status = "RESTARTING"
                        else:
                            # Đã restart mà vẫn ngoẻo -> Đổi acc khác luôn
                            status = "DEAD -> SKIP"
                            def _async_skip(p):
                                handle_signal(p)
                            threading.Thread(target=_async_skip, args=(pkg,), daemon=True).start()
                            RETRY_COUNTS[pkg] = 0
                    else:
                        status = "WAIT HB"
                        seen = f"{int(TIMEOUT_1 - diff)}s"

            idx = COOKIE_INDEXES.get(pkg, -1)
            nick = f"{idx+1}/{total_cookies}" if idx >= 0 and total_cookies > 0 else "-"
            rows.append((pkg, nick, status, seen))

        if time.time() - last_update > 1:
            last_update = time.time()
            clear_screen()
            print(f"\033[1;36m--- JK93S: FARM BELI (Target: {target_beli:,}) ---\033[0m")
            print("Logic: Farm đến khi đủ Beli -> Tự đổi Acc (No Loop).")
            if total_cookies > 0:
                print(f"Tổng số nick đã chạy: {TOTAL_ACCOUNTS_PROCESSED}/{total_cookies}")
            else:
                print(f"Tổng số nick đã chạy: {TOTAL_ACCOUNTS_PROCESSED}")
            print("Ấn 9 + Enter để dừng\n")
            print(f"{'PACKAGE':<30} | {'NICK':<10} | {'STATUS':<12} | {'SEEN/WAIT':<12}")
            print("-" * 60)
            for pkg, nick, status, seen in rows:
                print(f"{pkg:<30} | {nick:<10} | {status:<12} | {seen:<12}")
            sys.stdout.flush()
        time.sleep(1)

class SignalHandler(BaseHTTPRequestHandler):
    def do_GET(self):
        try:
            path = self.path
            from urllib.parse import urlparse, parse_qs
            u = urlparse(path)
            qs = parse_qs(u.query)
            pkg = qs.get('package', [''])[0] or qs.get('pkg', [''])[0]
            if u.path == '/status':
                self.send_response(200)
                self.send_header("Content-Type", "application/json")
                self.end_headers()
                self.wfile.write(json.dumps({"ok": True, "ts": time.time()}).encode("utf-8"))
                return
            if u.path == '/hello':
                self.send_response(200)
                self.end_headers()
                self.wfile.write(b"OK")
                return
            if u.path == '/switch_vip':
                idx_str = qs.get('index', [''])[0] or qs.get('slot', [''])[0] or qs.get('i', [''])[0]
                try:
                    idx = int(idx_str)
                except Exception:
                    self.send_response(400)
                    self.end_headers()
                    self.wfile.write(b"Missing index")
                    return
                # fallback pkg if missing
                if not pkg:
                    pkgs = find_roblox_packages()
                    if len(pkgs) == 1:
                        pkg = pkgs[0]
                ok, msg = switch_vip_index(idx, pkg=pkg)
                self.send_response(200 if ok else 400)
                self.end_headers()
                self.wfile.write(msg.encode("utf-8"))
                return
            if not pkg and u.path in ['/change_account', '/reset_game']:
                pkgs = find_roblox_packages()
                if len(pkgs) == 1:
                    pkg = pkgs[0]
                else:
                    self.send_response(400)
                    self.end_headers()
                    self.wfile.write(b"Missing package")
                    return
            if u.path == '/change_account':
                t = threading.Thread(target=handle_signal, args=(pkg,))
                t.start()
                self.send_response(200)
                self.end_headers()
                self.wfile.write(b"OK")
                return
            if u.path == '/reset_game':
                t = threading.Thread(target=handle_reset, args=(pkg,))
                t.start()
                self.send_response(200)
                self.end_headers()
                self.wfile.write(b"OK")
                return
            if u.path == '/signal':
                sig = qs.get('signal', [''])[0] or qs.get('Signal', [''])[0]
                if sig:
                     print(f"[DEBUG] Nhận tín hiệu (GET) '{sig}' từ {pkg or 'Unknown'}")
                
                # [FIX] Try to resolve pkg by username if missing
                if not pkg:
                    uname = qs.get('username', [''])[0] or qs.get('user', [''])[0]
                    if uname:
                        for p, u_map in PKG_USERNAMES.items():
                            if u_map == uname:
                                pkg = p
                                print(f"[DEBUG] Auto-map username '{uname}' -> {pkg}")
                                break
                    
                    # Last resort: if only 1 package exists
                    if not pkg:
                        pkgs = find_roblox_packages()
                        if len(pkgs) == 1:
                            pkg = pkgs[0]

                if sig == "NotEnoughBeli":
                    print(f"\n[SIGNAL HTTP GET] {pkg}: Không đủ Beli -> Switch VIP 2 (Farm)...")
                    t = threading.Thread(target=handle_signal, args=(pkg, 1))
                    t.start()
                elif sig == "EnoughBeliFarmDone":
                    print(f"\n[SIGNAL HTTP GET] {pkg}: Đã đủ Beli -> Switch VIP 1 (Random)...")
                    t = threading.Thread(target=handle_signal, args=(pkg, 0))
                    t.start()
                elif sig == "ChangeAccount":
                    print(f"\n[SIGNAL HTTP GET] {pkg}: Change Account Request")
                    t = threading.Thread(target=handle_signal, args=(pkg,))
                    t.start()
                elif sig == "Kicked":
                    print(f"\n[SIGNAL HTTP GET] {pkg}: BỊ KICK! -> Auto Rejoin ngay lập tức...")
                    t = threading.Thread(target=handle_reset, args=(pkg,))
                    t.start()
                
                self.send_response(200)
                self.end_headers()
                self.wfile.write(b"OK")
                return
            if u.path == '/heartbeat':
                # Try to infer pkg if missing (Single instance case)
                if not pkg:
                    pkgs = find_roblox_packages()
                    if len(pkgs) == 1:
                        pkg = pkgs[0]
                
                uname = qs.get('username', [''])[0] or qs.get('user', [''])[0]
                stype = qs.get('server_type', [''])[0] or qs.get('type', [''])[0]
                beli = qs.get('beli', [''])[0] or qs.get('money', [''])[0]
                
                if pkg:
                    HEARTBEAT_DATA[pkg] = time.time()
                    if uname:
                        PKG_USERNAMES[pkg] = uname
                    if stype:
                        if pkg not in HEARTBEAT_INFO: HEARTBEAT_INFO[pkg] = {}
                        HEARTBEAT_INFO[pkg]['server_type'] = stype
                    if beli != "":
                        try:
                            if pkg not in HEARTBEAT_INFO: HEARTBEAT_INFO[pkg] = {}
                            HEARTBEAT_INFO[pkg]['beli'] = int(float(beli))
                        except Exception:
                            pass
                else:
                    # Broadcast heartbeat if pkg unknown
                    for p in find_roblox_packages():
                        HEARTBEAT_DATA[p] = time.time()
                        # Cannot map username safely here without pkg
                
                self.send_response(200)
                self.end_headers()
                self.wfile.write(b"OK")
                return
            self.send_response(404)
            self.end_headers()
        except Exception as e:
            print(f"Server Error: {e}")
            self.send_response(500)
            self.end_headers()
    def do_POST(self):
        try:
            content_length = int(self.headers.get('Content-Length', 0))
            post_data = self.rfile.read(content_length)
            data = json.loads(post_data.decode('utf-8'))
            pkg = data.get('package') or data.get('pkg')
            
            # In log debug để user thấy tín hiệu đã tới
            sig = data.get('signal') or data.get('Signal')
            if sig:
                 print(f"[DEBUG] Nhận tín hiệu '{sig}' từ {pkg or 'Unknown'}")

            if not pkg:
                # [FIX] Try to find pkg by username
                uname = data.get('username') or data.get('user')
                if uname:
                    for p, u in PKG_USERNAMES.items():
                        if u == uname:
                            pkg = p
                            print(f"[DEBUG] Auto-map username '{uname}' -> {pkg}")
                            break
                
                if not pkg:
                    pkgs = find_roblox_packages()
                    if len(pkgs) == 1:
                        pkg = pkgs[0]
                    else:
                        # [FIX] Instead of rejecting, broadcast to all to keep them alive
                        # This is safer than 400 Error which causes OFFLINE
                        print(f"[WARN] Heartbeat missing pkg & username unknown. Broadcast to {len(pkgs)} pkgs.")
                        for p in pkgs:
                            HEARTBEAT_DATA[p] = time.time()
                        self.send_response(200)
                        self.wfile.write(b"OK (Broadcast)")
                        return

            if self.path == '/change_account':
                t = threading.Thread(target=handle_signal, args=(pkg,))
                t.start()
                self.send_response(200)
                self.wfile.write(b"OK")
                
            elif self.path == '/reset_game':
                t = threading.Thread(target=handle_reset, args=(pkg,))
                t.start()
                self.send_response(200)
                self.wfile.write(b"OK")
                
            elif self.path == '/heartbeat':
                if pkg:
                    HEARTBEAT_DATA[pkg] = time.time()
                    # [FIX] Update username mapping for robust pkg detection
                    uname = data.get('username') or data.get('user')
                    if uname:
                        PKG_USERNAMES[pkg] = uname
                    
                    stype = data.get('server_type') or data.get('type')
                    if stype:
                        if pkg not in HEARTBEAT_INFO: HEARTBEAT_INFO[pkg] = {}
                        HEARTBEAT_INFO[pkg]['server_type'] = stype
                else:
                    for p in find_roblox_packages():
                        HEARTBEAT_DATA[p] = time.time()
                self.send_response(200)
                self.wfile.write(b"OK")
            
            elif self.path == '/signal':
                sig = data.get('signal') or data.get('Signal')
                if sig == "NotEnoughBeli":
                    print(f"\n[SIGNAL HTTP] {pkg}: Không đủ Beli -> Switch VIP 2 (Farm)...")
                    t = threading.Thread(target=handle_signal, args=(pkg, 1))
                    t.start()
                elif sig == "EnoughBeliFarmDone":
                    print(f"\n[SIGNAL HTTP] {pkg}: Đã đủ Beli -> Switch VIP 1 (Random)...")
                    t = threading.Thread(target=handle_signal, args=(pkg, 0))
                    t.start()
                elif sig == "ChangeAccount":
                    print(f"\n[SIGNAL HTTP] {pkg}: Change Account Request")
                    t = threading.Thread(target=handle_signal, args=(pkg,))
                    t.start()
                elif sig == "Kicked":
                    print(f"\n[SIGNAL HTTP] {pkg}: BỊ KICK! -> Auto Rejoin ngay lập tức...")
                    t = threading.Thread(target=handle_reset, args=(pkg,))
                    t.start()
                
                self.send_response(200)
                self.wfile.write(b"OK")

            elif self.path == '/switch_vip':
                idx = data.get('index') or data.get('slot') or data.get('i')
                try:
                    idx = int(idx)
                except Exception:
                    self.send_response(400)
                    self.end_headers()
                    self.wfile.write(b"Missing index")
                    return
                ok, msg = switch_vip_index(idx, pkg=pkg)
                self.send_response(200 if ok else 400)
                self.wfile.write(msg.encode("utf-8"))
                
            elif self.path == '/hello':
                self.send_response(200)
                self.wfile.write(b"OK")
                
            else:
                self.send_response(404)
                self.end_headers()
                
        except Exception as e:
            print(f"Server Error: {e}")
            self.send_response(500)
            self.end_headers()
            
    def log_message(self, format, *args):
        # Suppress log
        pass

def ensure_adb_reverse_loop(port):
    while True:
        try:
            devices = get_adb_devices()
            if not devices:
                # print(f" -> [WARN] Không tìm thấy thiết bị ADB nào để reverse port {port}!")
                pass
            else:
                for dev in devices:
                    # Chạy ngầm để không spam log
                    subprocess.run(f"adb -s {dev} reverse tcp:{port} tcp:{port}", shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except Exception:
            pass
        time.sleep(60) # Check lại mỗi 60s

def start_server_thread(port=8000):
    # Kích hoạt ADB Reverse ngay lập tức
    try:
        devices = get_adb_devices()
        if not devices:
            print(f" -> [WARN] Không tìm thấy thiết bị ADB nào để reverse port {port}!")
        
        for dev in devices:
            print(f" -> Setup ADB Reverse tcp:{port} for {dev}...")
            subprocess.run(f"adb -s {dev} reverse tcp:{port} tcp:{port}", shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            
    except Exception as e:
        print(f"Lỗi ADB Reverse: {e}")

    # Chạy luồng duy trì ADB Reverse
    t_rev = threading.Thread(target=ensure_adb_reverse_loop, args=(port,))
    t_rev.daemon = True
    t_rev.start()

    server = HTTPServer(('0.0.0.0', port), SignalHandler)
    t = threading.Thread(target=server.serve_forever)
    t.daemon = True
    t.start()
    return server

