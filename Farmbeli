local function urlEncode(str)
    if str == nil then return "" end
    str = tostring(str)
    str = string.gsub(str, "\n", "\r\n")
    str = string.gsub(str, "([^%w%-_%.~])", function(c)
        return string.format("%%%02X", string.byte(c))
    end)
    return str
end

function SendSignal(signalName, extraData)
    local pkgName = readPkgName()
    local uname = getUsername()
    local nonce = tostring(math.random(100000, 999999))
    local data = {
        username = uname,
        signal = signalName,
        nonce = nonce
    }
    if pkgName and pkgName ~= "" and pkgName ~= "unknown" then
        data.package = pkgName
    end
    if extraData then
        for k, v in pairs(extraData) do
            data[k] = v
        end
    end
    
    local body = HttpService:JSONEncode(data)
    local req = (syn and syn.request) or (http and http.request) or http_request or request

    for _, base in ipairs(BASES) do
        local url = base .. "/signal"
        if req then
            pcall(function()
                req({
                    Url = url,
                    Method = "POST",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = body
                })
            end)
        end
        pcall(function()
            HttpService:RequestAsync({
                Url = url,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = body
            })
        end)

        local qs = "?signal=" .. urlEncode(signalName) .. "&username=" .. urlEncode(uname) .. "&nonce=" .. urlEncode(nonce)
        if pkgName and pkgName ~= "" and pkgName ~= "unknown" then
            qs = qs .. "&package=" .. urlEncode(pkgName)
        end
        local getUrl = base .. "/signal" .. qs
        if req then
            pcall(function()
                req({Url = getUrl, Method = "GET"})
            end)
        end
        pcall(function()
            HttpService:RequestAsync({
                Url = getUrl,
                Method = "GET",
                Headers = {["Content-Type"] = "application/json"}
            })
        end)
    end

    local fields = {
        username = uname,
        Signal = signalName,
        Nonce = nonce,
        Heartbeat = os.time()
    }
    if pkgName and pkgName ~= "" and pkgName ~= "unknown" then
        fields.PkgName = pkgName
    end
    writeAppStorage(fields)
end

local LAST_KICK_SENT = 0
local function notifyKick()
    local kicked, code, snippet = isKicked()
    if not kicked then
        return false
    end
    local now = os.clock()
    if now - LAST_KICK_SENT >= 8 then
        LAST_KICK_SENT = now
        pcall(function()
            SendSignal("Kicked", {code = code or "", msg = snippet or ""})
        end)
    end
    return true
end

