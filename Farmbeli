def resolve_vip_links(cfg):
    vip1 = cfg.get("vip1_url") or ""
    vip2 = cfg.get("vip2_url") or ""
    
    def clean(u):
        if u and isinstance(u, str):
            return u.replace('`', '').strip()
        return ""
    
    vip1 = clean(vip1)
    vip2 = clean(vip2)
    
    res = []
    if vip1:
        res.append(vip1)
    if vip2:
        res.append(vip2)
    return res

