local function urlEncode(str)
    if str == nil then return "" end
    str = tostring(str)
    str = string.gsub(str, "\n", "\r\n")
    str = string.gsub(str, "([^%w%-_%.~])", function(c)
        return string.format("%%%02X", string.byte(c))
    end)
    return str
end

function SendSignal(signalName, extraData)
    local pkgName = readPkgName()
    local uname = getUsername()
    local nonce = tostring(math.random(100000, 999999))
    local data = {
        username = uname,
        signal = signalName,
        nonce = nonce
    }
    if pkgName and pkgName ~= "" and pkgName ~= "unknown" then
        data.package = pkgName
    end
    if extraData then
        for k, v in pairs(extraData) do
            data[k] = v
        end
    end
    
    local body = HttpService:JSONEncode(data)
    local req = (syn and syn.request) or (http and http.request) or http_request or request

    for _, base in ipairs(BASES) do
        local url = base .. "/signal"
        if req then
            pcall(function()
                req({
                    Url = url,
                    Method = "POST",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = body
                })
            end)
        end
        pcall(function()
            HttpService:RequestAsync({
                Url = url,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = body
            })
        end)

        local qs = "?signal=" .. urlEncode(signalName) .. "&username=" .. urlEncode(uname) .. "&nonce=" .. urlEncode(nonce)
        if pkgName and pkgName ~= "" and pkgName ~= "unknown" then
            qs = qs .. "&package=" .. urlEncode(pkgName)
        end
        local getUrl = base .. "/signal" .. qs
        if req then
            pcall(function()
                req({Url = getUrl, Method = "GET"})
            end)
        end
        pcall(function()
            HttpService:RequestAsync({
                Url = getUrl,
                Method = "GET",
                Headers = {["Content-Type"] = "application/json"}
            })
        end)
    end

    local fields = {
        username = uname,
        Signal = signalName,
        Nonce = nonce,
        Heartbeat = os.time()
    }
    if pkgName and pkgName ~= "" and pkgName ~= "unknown" then
        fields.PkgName = pkgName
    end
    writeAppStorage(fields)
end

function SendReset(reason, code)
    local pkgName = readPkgName()
    local uname = getUsername()
    local nonce = tostring(math.random(100000, 999999))
    local data = {
        username = uname,
        signal = "Kicked", -- Giữ Kicked để Python handle_reset
        reason = reason or "Unknown Error",
        code = code or "0",
        nonce = nonce
    }
    if pkgName and pkgName ~= "" and pkgName ~= "unknown" then
        data.package = pkgName
    end

    local body = HttpService:JSONEncode(data)
    local req = (syn and syn.request) or (http and http.request) or http_request or request

    for _, base in ipairs(BASES) do
        -- 1. Gửi tới /reset_game (Lệnh trực tiếp)
        pcall(function()
            local url = base .. "/reset_game"
            if req then
                req({
                    Url = url,
                    Method = "POST",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = body
                })
            else
                HttpService:RequestAsync({
                    Url = url,
                    Method = "POST",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = body
                })
            end
        end)

        -- 2. Gửi tới /signal?signal=Kicked (Redundancy)
        pcall(function()
            local url = base .. "/signal?signal=Kicked&username=" .. urlEncode(uname) .. "&package=" .. urlEncode(pkgName or "")
            if req then
                req({Url = url, Method = "GET"})
            else
                HttpService:RequestAsync({Url = url, Method = "GET"})
            end
        end)
    end

    -- 3. Ghi vào appStorage (Backup nếu mất mạng/HTTP lỗi)
    local fields = {
        username = uname,
        Signal = "Kicked",
        Reason = reason,
        Code = code,
        Nonce = nonce,
        Heartbeat = os.time()
    }
    if pkgName and pkgName ~= "" and pkgName ~= "unknown" then
        fields.PkgName = pkgName
    end
    writeAppStorage(fields)
    print("[RESET] Đã gửi tín hiệu reset cho Python: " .. tostring(reason))
end

local LAST_KICK_SENT = 0
local function notifyKick()
    local kicked, code, snippet = isKicked()
    
    -- Check thêm lỗi Teleport bị kẹt
    if not kicked then
        -- Tăng thời gian check lên 15s và chỉ check khi đã vào game đủ lâu (>20s)
        if os.clock() > 20 and TELEPORT_FAIL_TS > 0 and os.clock() - TELEPORT_FAIL_TS < 15 then
            kicked = true
            code = tostring(TELEPORT_FAIL_RESULT)
            snippet = "Teleport Failed: " .. tostring(TELEPORT_FAIL_MSG)
        end
    end

    if not kicked then
        return false
    end
    
    local now = os.clock()
    -- Giãn cách gửi tín hiệu Reset ít nhất 15 giây để tránh spam reset loop
    if now - LAST_KICK_SENT >= 15 then
        LAST_KICK_SENT = now
        pcall(function()
            SendReset(snippet, code)
        end)
    end
    return true
end

